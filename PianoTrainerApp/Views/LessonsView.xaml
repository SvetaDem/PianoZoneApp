<UserControl x:Class="PianoTrainerApp.Views.LessonsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PianoTrainerApp.Views"
             mc:Ignorable="d" 
             Width="Auto" Height="Auto">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Вкладки категории -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="Новичок" Width="100" Margin="5" Click="CategoryButton_Click"/>
            <Button Content="Средний" Width="100" Margin="5" Click="CategoryButton_Click"/>
            <Button Content="Продвинутый" Width="100" Margin="5" Click="CategoryButton_Click"/>
        </StackPanel>

        <!-- Горизонтальный ListView с видео -->
        <ListView x:Name="LessonsListView"
                  Grid.Row="1"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  ItemsSource="{Binding CurrentLessons}"
                  HorizontalAlignment="Stretch"
                  Height="350"
                  Background="Transparent"
                  BorderThickness="0">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="300" Height="320" Margin="5" CornerRadius="15" BorderBrush="#3F64A9" BorderThickness="1" Background="#f9f9f9">
                        <StackPanel>
                            <!-- Заголовок урока -->
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Margin="10,10,10,5" TextWrapping="Wrap"/>

                            <!-- Видео через WebBrowser -->
                            <WebBrowser x:Name="LessonWebBrowser" Margin="10,0,10,10" Loaded="WebBrowser_Loaded"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
