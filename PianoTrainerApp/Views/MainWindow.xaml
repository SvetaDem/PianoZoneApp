<Window x:Class="PianoTrainerApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PianoTrainerApp.Views"
        mc:Ignorable="d"
        Title="Планета Ре-минор" Height="650" Width="1050"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Стиль вкладок навигации -->
        <Style x:Key="NavTabTextStyle" TargetType="TextBlock">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <!-- Hover эффект -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Универсальный стиль кнопки-иконки (profile/settings/exit) -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="#1e1e1e"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="#8F8F8F"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="20"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <!-- ВАЖНО: тут живёт текст -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Фокус -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6A9FFF"/>
                                <Setter Property="Background" Value="#A5A5A5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>


    <Grid>
        <!-- Фон -->
        <Grid.Background>
            <ImageBrush ImageSource="/Images/main_background.png" Stretch="Fill"/>
        </Grid.Background>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Grid Margin="20,0" Height="60" VerticalAlignment="Top">

            <!-- Заголовок -->
            <TextBlock Text="Планета Ре-минор"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Black"/>

            <!-- Среднее меню -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock Text="Главная"
                           Foreground="White"
                           FontSize="20"
                           Cursor="Hand"
                           Margin="0,0,25,0"
                           Style="{StaticResource NavTabTextStyle}"
                           FontWeight="Medium"
                           VerticalAlignment="Bottom"/>

                <TextBlock Text="|"
                           Foreground="#202020"
                           FontSize="20"
                           FontWeight="Medium"
                           Margin="0,0,25,0"
                           VerticalAlignment="Bottom"/>

                <TextBlock Text="Обучение"
                           Foreground="#202020"
                           FontSize="16"
                           FontWeight="Medium"
                           Cursor="Hand"
                           Style="{StaticResource NavTabTextStyle}"
                           Margin="0,0,25,0"
                           MouseLeftButtonDown="ButtonBeginner_Click"
                           VerticalAlignment="Bottom"/>

                <TextBlock Text="|"
                           Foreground="#202020"
                           FontSize="20"
                           FontWeight="Medium"
                           Margin="0,0,25,0"
                           VerticalAlignment="Bottom"/>

                <TextBlock Text="Музыка"
                           Foreground="#202020"
                           FontSize="16"
                           Cursor="Hand"
                           Style="{StaticResource NavTabTextStyle}"
                           FontWeight="Medium"
                           MouseLeftButtonDown="ButtonLibrary_Click"
                           VerticalAlignment="Bottom"/>
            </StackPanel>

        </Grid>

        <!-- Иконки справа -->
        <StackPanel Orientation="Vertical"
            VerticalAlignment="Top"
                    Margin="20"
            HorizontalAlignment="Right">

            <Button Width="32" Height="32" Margin="0,0,0,10"
                    Style="{StaticResource IconButtonStyle}"
                    Click="ProfileButton_Click">
                <Image Source="/Images/profile.png"/>
            </Button>

            <Button Width="32" Height="32"
                    Style="{StaticResource IconButtonStyle}"
                    >
                <Image Source="/Images/settings.png"/>
            </Button>
        </StackPanel>

        <!-- ЦЕНТРАЛЬНЫЕ КАРТОЧКИ -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Левая карточка -->
            <Button Cursor="Hand"
                    Background="Black"
                    BorderBrush="White"
                    BorderThickness="2"
                    Margin="0,0,60,0"
                    Width="330" Height="340"
                    Click="ButtonBeginner_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="25"
                            RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect
                                    Color="#868686"
                                    BlurRadius="50"
                                    ShadowDepth="0"
                                    Direction="0"
                                    Opacity="0.5"/>
                            </Border.Effect>

                            <!-- Внутренний контейнер для текста -->
                            <StackPanel Margin="34,38,70,15" VerticalAlignment="Top">
                                <!-- Заголовок -->
                                <TextBlock
                                    Text="Новичок?"
                                    Foreground="White"
                                    FontSize="22"
                                    FontWeight="ExtraBold"/>

                                <!-- Подзаголовок с разной жирностью -->
                                <TextBlock
                                    Foreground="White"
                                    FontSize="16"
                                    Margin="0,30,0,40"
                                    TextWrapping="Wrap">
                                    <Run Text="Не волнуйся и переходи" FontWeight="Light"/>
                                    <LineBreak/>
                                    <Run Text="к изучению основ" FontWeight="Medium"/>
                                </TextBlock>
                                <Image
                                    Height="110"
                                    Margin="0,10,0,0"
                                    Source="/Images/piano.png"/>
                            </StackPanel>
                        </Border>
                        <!-- Триггеры анимаций -->
                        <ControlTemplate.Triggers>
                            <!-- Наведение -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Увеличение -->
                                            <DoubleAnimation
                                                Storyboard.TargetName="border"
                                                Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                                To="1.05" Duration="0:0:0.15"/>
                                            <DoubleAnimation
                                                Storyboard.TargetName="border"
                                                Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                                To="1.05" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Возврат -->
                                            <DoubleAnimation
                                                Storyboard.TargetName="border"
                                                Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                                To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation
                                                Storyboard.TargetName="border"
                                                Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                                To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>


            <!-- Правая карточка -->
            <Button
                Cursor="Hand"
                Background="White"
                BorderBrush="Black"
                BorderThickness="2"
                Width="330" Height="340"
                Click="ButtonLibrary_Click">

                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <!-- Масштабирование всей кнопки -->
                        <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="25"
                    RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <Border.Effect>
                                <DropShadowEffect
                        Color="#868686"
                        BlurRadius="50"
                        ShadowDepth="0"
                        Direction="0"
                        Opacity="0.5"/>
                            </Border.Effect>

                            <!-- Контент -->
                            <StackPanel Margin="34,38,15,38" VerticalAlignment="Top">
                                <TextBlock Text="Давай играть!"
                               Foreground="Black"
                               FontSize="22"
                               FontWeight="ExtraBold"/>

                                <TextBlock Foreground="Black"
                               FontSize="16"
                               Margin="0,30,0,20"
                               TextWrapping="Wrap">
                        <Run Foreground="#564949"
                             Text="Переходи в библиотеку и"
                             FontWeight="Regular"/>
                        <LineBreak/>
                        <Run Text="выбирай песню по душе"
                             FontWeight="Medium"/>
                                </TextBlock>

                                <Image Source="/Images/go_on.png"
                           Height="50"
                           Margin="-10,0"
                           HorizontalAlignment="Left"/>

                                <Image Width="190"
                           Margin="0,-70"
                           HorizontalAlignment="Right"
                           Source="/Images/piano_player.png"/>
                            </StackPanel>
                        </Border>

                        <!-- Триггеры анимаций -->
                        <ControlTemplate.Triggers>
                            <!-- Наведение -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Увеличение -->
                                            <DoubleAnimation
                                    Storyboard.TargetName="border"
                                    Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                    To="1.05" Duration="0:0:0.15"/>
                                            <DoubleAnimation
                                    Storyboard.TargetName="border"
                                    Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                    To="1.05" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Возврат -->
                                            <DoubleAnimation
                                    Storyboard.TargetName="border"
                                    Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                    To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation
                                    Storyboard.TargetName="border"
                                    Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                    To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>

        <!-- Затемнение фона -->
        <Border x:Name="Overlay"
        Background="#66000000"
        Visibility="Collapsed"
        Panel.ZIndex="9"
        MouseDown="Overlay_MouseDown"/>

        <!-- ВЫЕЗЖАЮЩАЯ ПАНЕЛЬ ПРОФИЛЯ -->
        <Grid x:Name="ProfilePanel"
      Width="350"
      HorizontalAlignment="Right"
      Background="#1E1E1E"
      Panel.ZIndex="10">

            <Grid.RenderTransform>
                <TranslateTransform x:Name="ProfilePanelTransform" X="350"/>
            </Grid.RenderTransform>


            <!-- Контент -->
            <Grid>

                <!-- ЭКРАН АВТОРИЗАЦИИ -->
                <StackPanel x:Name="AuthPanel"
                    Margin="30"
                            Visibility="Visible"
                    VerticalAlignment="Center" Cursor="">

                    <TextBlock Text="Авторизация"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Grid>
                        <TextBox x:Name="AuthUsernameTextBox"
                 Style="{StaticResource RoundedTextBox}"
                 TextChanged="TextBox_TextChanged"/>
                        <TextBlock Text="Логин"
                   Foreground="#555555"
                   Margin="24,0,24,15"
                                   FontWeight="Medium"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   x:Name="AuthUsernamePlaceholder"/>
                    </Grid>

                    <Grid>
                        <TextBox x:Name="AuthPasswordBox"
                 Style="{StaticResource RoundedTextBox}"
                 TextChanged="PasswordBox_TextChanged"
                 LostFocus="PasswordBox_LostFocus"
                 Loaded="PasswordBox_Loaded"/>

                        <!-- Placeholder -->
                        <TextBlock Text="Пароль"
                   Foreground="#555555"
                                   FontWeight="Medium"
                   Margin="24,0,50,15"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   x:Name="AuthPasswordPlaceholder"/>

                        <!-- Глазик -->
                        <Button x:Name="AuthShowPasswordButton"
                Width="30" Height="30"
                HorizontalAlignment="Right"
                Background="Transparent"
                BorderThickness="0"
                                Margin="25,0,10,15"
                Cursor="Hand"
                PreviewMouseLeftButtonDown="ShowPasswordButton_PreviewMouseLeftButtonDown"
                PreviewMouseLeftButtonUp="ShowPasswordButton_PreviewMouseLeftButtonUp">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="👁" FontSize="14"/>
                        </Button>
                    </Grid>

                    <Button x:Name="AuthButton" Width="120" Height="38"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                            Margin="0,10,0,0"
                        Background="#3F64A9"
                            Click="ButtonLogin_Click"
                        BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20">
                                    <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Войти"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Изменение цвета при наведении -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#5F84C9"/>
                                        <!-- более тёмный -->
                                    </Trigger>
                                    <!-- нажатие -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#7FA4E9"/>
                                        <!-- ещё темнее -->
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="Нет аккаунта?"
                               Foreground="#9b9b9b"
                               TextAlignment="Center"
                               Margin="0,15,0,0"
                               Cursor="Hand"/>

                    <TextBlock Text="Зарегистрируйся"
                               Foreground="#e0e0e0"
                               TextAlignment="Center"
                               Cursor="Hand"
                               MouseLeftButtonDown="RegisterTextBlock_Click"/>
                </StackPanel>

                <!-- ЭКРАН РЕГИСТРАЦИИ -->
                <StackPanel x:Name="RegisterPanel"
                    Margin="30"
                            Visibility="Collapsed"
                    VerticalAlignment="Center" Cursor="">

                    <TextBlock Text="Регистрация"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Grid>
                        <TextBox x:Name="RegisterUsernameTextBox"
                 Style="{StaticResource RoundedTextBox}"
                 TextChanged="TextBox_TextChanged">
                            <TextBox.ToolTip>
                                <ToolTip Background="#2b2b2b" Foreground="White" Padding="10" BorderThickness="0">
                                    <TextBlock TextWrapping="Wrap" Width="220">
                <Run Text="Логин должен быть:"/>
                                        <LineBreak/>
                <Run Text="• от 3 до 32 символов"/>
                                        <LineBreak/>
                <Run Text="• начинаться с буквы"/>
                                            <LineBreak/>
                <Run Text="• содержать только буквы, цифры и символы: _ . -"/>
                            <LineBreak/>
                <Run Text="• без подряд идущих спецсимволов (_ . -)"/>
                                    </TextBlock>
                                </ToolTip>
                            </TextBox.ToolTip>
                        </TextBox>
                        <TextBlock Text="Логин"
                   Foreground="#555555"
                   Margin="24,0,24,15"
                                   FontWeight="Medium"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   x:Name="RegisterUsernamePlaceholder"/>
                    </Grid>

                    <Grid>
                        <TextBox x:Name="RegisterEmailTextBox"
                                Style="{StaticResource RoundedTextBox}"
                                TextChanged="TextBox_TextChanged">
                            <TextBox.ToolTip>
                                <ToolTip Background="#2b2b2b" Foreground="White" Padding="10" BorderThickness="0">
                                    <TextBlock TextWrapping="Wrap" Width="220">
                Email должен соответсвовать формату example@example.com
                                    </TextBlock>
                                </ToolTip>
                            </TextBox.ToolTip>
                        </TextBox>
                        <TextBlock Text="E-mail"
                                  Foreground="#555555"
                                  Margin="24,0,24,15"
                                  FontWeight="Medium"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  x:Name="RegisterEmailPlaceholder"/>
                    </Grid>

                    <Grid>
                        <TextBox x:Name="RegisterPasswordBox"
                                 Style="{StaticResource RoundedTextBox}"
                                 TextChanged="PasswordBox_TextChanged"
                                 LostFocus="PasswordBox_LostFocus"
                                 Loaded="PasswordBox_Loaded">
                            <TextBox.ToolTip>
                                <ToolTip Background="#2b2b2b" Foreground="White" Padding="10" BorderThickness="0">
                                    <TextBlock TextWrapping="Wrap" Width="220">
                <Run Text="Пароль должен быть:"/>
                                        <LineBreak/>
                <Run Text="• от 6 до 32 символов"/>
                                            <LineBreak/>
                <Run Text="• содержать хотя бы 1 заглавную, 1 строчную букву и цифру"/>
                                    </TextBlock>
                                </ToolTip>
                            </TextBox.ToolTip>
                        </TextBox>

                        <!-- Placeholder -->
                        <TextBlock Text="Пароль"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="24,0,50,15"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   x:Name="RegisterPasswordPlaceholder"/>

                        <!-- Глазик -->
                        <Button x:Name="RegisterShowPasswordButton"
                                Width="30" Height="30"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="25,0,10,15"
                                Cursor="Hand"
                                PreviewMouseLeftButtonDown="ShowPasswordButton_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ShowPasswordButton_PreviewMouseLeftButtonUp">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="👁" FontSize="14"/>
                        </Button>
                    </Grid>

                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="RegisterButton" Width="120" Height="38"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                                Grid.Column="0"
                            Margin="0,10,0,0"
                        Background="#3F64A9"
                            Click="ButtonLogin_Click"
                        BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20">
                                        <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Войти"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Изменение цвета при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#5F84C9"/>
                                            <!-- более тёмный -->
                                        </Trigger>
                                        <!-- нажатие -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#7FA4E9"/>
                                            <!-- ещё темнее -->
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BackButton" Width="120" Height="38"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                                Grid.Column="2"
                            Margin="0,10,0,0"
                        Background="#E0E0E0"
                            Click="ButtonBack_Click"
                        BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20">
                                        <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Назад"
                                           FontWeight="SemiBold"
                                           Foreground="#1e1e1e"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Изменение цвета при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#C0C0C0"/>
                                            <!-- более тёмный -->
                                        </Trigger>
                                        <!-- нажатие -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#a0a0a0"/>
                                            <!-- ещё темнее -->
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                </StackPanel>

                <!-- ПРОФИЛЬ ПОЛЬЗОВАТЕЛЯ -->
                <StackPanel x:Name="UserPanel"
                    Margin="25"
                    Visibility="Collapsed"
                    VerticalAlignment="Center">

                    <TextBlock Text="Добро пожаловать!"
                       Foreground="White"
                       FontSize="20"
                       Margin="0,0,0,15"/>

                    <TextBlock x:Name="UsernameProfileText"
           FontSize="18"
           Foreground="White"/>

                    <Button Content="Выйти"
                    Margin="0,20,0,0"
                    Height="35"
                            Click="ButtonLogout_Click"/>
                </StackPanel>

            </Grid>
        </Grid>

        <!-- КНОПКА ВЫХОД -->
        <Button
            Width="32" Height="32" Margin="20"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="ButtonExit_Click"
            Style="{StaticResource IconButtonStyle}">
            <Image Source="/Images/exit.png"/>
        </Button>


    </Grid>
</Window>