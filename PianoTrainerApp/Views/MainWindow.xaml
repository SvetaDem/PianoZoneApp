<Window x:Class="PianoTrainerApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PianoTrainerApp.Views"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        mc:Ignorable="d"
        Title="Планета Ре-минор" Height="650" Width="1050"
        MinHeight="650" MinWidth="1050"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Универсальный стиль кнопки-иконки (profile/settings/exit) -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1.1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1.1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                         To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                         To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Универсальный стиль TextBox -->
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="#1e1e1e"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="#8F8F8F"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="20"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <!-- ВАЖНО: тут живёт текст -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Фокус -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#6A9FFF"/>
                                <Setter Property="Background" Value="#A5A5A5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль TextBox для панели редактирования -->
        <Style x:Key="TransparentTextBox"
       TargetType="TextBox"
       BasedOn="{StaticResource RoundedTextBox}">

            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#e0e0e0"/>
            <Setter Property="CaretBrush" Value="White"/>

            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Фон -->
        <Grid.Background>
            <ImageBrush ImageSource="/Images/main_background.png" Stretch="Fill"/>
        </Grid.Background>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Grid Margin="20,0" Height="60" VerticalAlignment="Top" Cursor="">

            <!-- Заголовок -->
            <TextBlock Text="Планета Ре-минор"
                       VerticalAlignment="Center"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Black"/>

            <!-- Среднее меню -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock x:Name="HomeTextBlock"
                           Text="Главная"
                           Foreground="White"
                           FontSize="16"
                           Cursor="Hand"
                           Margin="0,0,25,0"
                           FontWeight="Medium"
                           MouseLeftButtonUp="MenuTextBlock_Click"
                           VerticalAlignment="Bottom"
                           RenderTransformOrigin="0.5,1">

                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock Text="|"
                           Foreground="#202020"
                           FontSize="20"
                           FontWeight="Medium"
                           Margin="0,0,25,0"
                           VerticalAlignment="Bottom"/>

                <TextBlock x:Name="LessonsTextBlock"
                           Text="Обучение"
                           Foreground="#202020"
                           FontSize="16"
                           FontWeight="Medium"
                           Cursor="Hand"
                           Margin="0,0,25,0"
                           MouseLeftButtonUp="MenuTextBlock_Click"
                           VerticalAlignment="Bottom"
                           RenderTransformOrigin="0.5,1">

                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock Text="|"
                           Foreground="#202020"
                           FontSize="20"
                           FontWeight="Medium"
                           Margin="0,0,25,0"
                           VerticalAlignment="Bottom"/>

                <TextBlock x:Name="LibraryTextBlock"
                           Text="Музыка"
                           Foreground="#202020"
                           FontSize="16"
                           Cursor="Hand"
                           FontWeight="Medium"
                           MouseLeftButtonUp="MenuTextBlock_Click"
                           VerticalAlignment="Bottom"
                           RenderTransformOrigin="0.5,1">

                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>

        </Grid>

        <!-- Иконки справа -->
        <StackPanel Orientation="Vertical"
            VerticalAlignment="Top"
                    Margin="20"
                    Grid.RowSpan="2"
            HorizontalAlignment="Right">

            <Button Width="32" Height="32" Margin="0,0,0,10"
                    Style="{StaticResource IconButtonStyle}"
                    Click="ProfileButton_Click">
                <!--<Image Source="/Images/profile.png"/>-->
                <svgc:SvgViewbox Source="/Images/profile.svg"/>
            </Button>
            

            <!--<Image x:Name="AdvancedImage"
       Height="154" Width="154"
       Source="{svgc:SvgImage Source=/Images/piano_hands_vector.svg}"
       Visibility="Visible"/>-->

            <Button Width="32" Height="32"
                    Style="{StaticResource IconButtonStyle}">
                <!--<Image Source="/Images/settings.png"/>-->
                <svgc:SvgViewbox Source="/Images/settings.svg"/>
            </Button>
        </StackPanel>

        <!-- Основной контент -->
        <ContentControl x:Name="MainContent" Grid.Row="1"/>

        <!-- Затемнение фона -->
        <Border x:Name="Overlay"
                Grid.RowSpan="2"
        Background="#66000000"
        Visibility="Collapsed"
        Panel.ZIndex="9"
        MouseDown="Overlay_MouseDown"/>

        <!-- ПАНЕЛЬ ПРОФИЛЯ -->
        <Grid x:Name="ProfilePanel"
      Width="350"
              Grid.RowSpan="2"
      HorizontalAlignment="Right"
      Background="#1E1E1E"
      Panel.ZIndex="10">

            <Grid.RenderTransform>
                <TranslateTransform x:Name="ProfilePanelTransform" X="350"/>
            </Grid.RenderTransform>


            <!-- Контент -->
            <Grid>

                <!-- ЭКРАН АВТОРИЗАЦИИ -->
                <StackPanel x:Name="AuthPanel"
                    Margin="30"
                            Visibility="Visible"
                    VerticalAlignment="Center" Cursor="">

                    <TextBlock Text="Авторизация"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Grid>
                        <TextBox x:Name="AuthUsernameTextBox"
                 Style="{StaticResource RoundedTextBox}"
                 TextChanged="TextBox_TextChanged"/>
                        <TextBlock Text="Логин"
                   Foreground="#555555"
                   Margin="24,0,24,15"
                                   FontWeight="Medium"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   x:Name="AuthUsernamePlaceholder"/>
                    </Grid>

                    <Grid>
                        <TextBox x:Name="AuthPasswordBox"
                                 Style="{StaticResource RoundedTextBox}"
                                 TextChanged="PasswordBox_TextChanged"
                                 LostFocus="PasswordBox_LostFocus"
                                 Loaded="PasswordBox_Loaded"
                                 DataObject.Pasting="PasswordBox_Pasting"/>

                        <!-- Placeholder -->
                        <TextBlock Text="Пароль"
                   Foreground="#555555"
                                   FontWeight="Medium"
                   Margin="24,0,50,15"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   x:Name="AuthPasswordPlaceholder"/>

                        <!-- Глазик -->
                        <Button x:Name="AuthShowPasswordButton"
                Width="30" Height="30"
                HorizontalAlignment="Right"
                Background="Transparent"
                BorderThickness="0"
                                Margin="25,0,10,15"
                Cursor="Hand"
                PreviewMouseLeftButtonDown="ShowPasswordButton_PreviewMouseLeftButtonDown"
                PreviewMouseLeftButtonUp="ShowPasswordButton_PreviewMouseLeftButtonUp">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="👁" FontSize="14"/>
                        </Button>
                    </Grid>

                    <Button x:Name="AuthButton" Width="120" Height="38"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                            Margin="0,10,0,0"
                        Background="#3F64A9"
                            Click="ButtonLogin_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="20">
                                    <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Войти"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <!-- Изменение цвета при наведении -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#5F84C9"/>
                                        <!-- более тёмный -->
                                    </Trigger>
                                    <!-- нажатие -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#7FA4E9"/>
                                        <!-- ещё темнее -->
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="Нет аккаунта?"
                               Foreground="#9b9b9b"
                               TextAlignment="Center"
                               FontSize="13"
                               Margin="0,15,0,0"
                               Cursor="Hand"/>

                    <TextBlock Text="Зарегистрируйся"
                               Foreground="#e0e0e0"
                               TextAlignment="Center"
                               FontSize="13"
                               Cursor="Hand"
                               MouseLeftButtonDown="RegisterTextBlock_Click"/>
                </StackPanel>

                <!-- ЭКРАН РЕГИСТРАЦИИ -->
                <StackPanel x:Name="RegisterPanel"
                    Margin="30"
                            Visibility="Collapsed"
                    VerticalAlignment="Center" Cursor="">

                    <TextBlock Text="Регистрация"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Grid>
                        <TextBox x:Name="RegisterUsernameTextBox"
                 Style="{StaticResource RoundedTextBox}"
                 TextChanged="TextBox_TextChanged">
                            <TextBox.ToolTip>
                                <ToolTip Placement="Right" HorizontalOffset="10">
                                    <ToolTip.Template>
                                        <ControlTemplate TargetType="ToolTip">
                                            <Border Background="#f9f9f9"
                                                    BorderBrush="#3F64A9"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10">
                                                <TextBlock TextWrapping="Wrap"
                                                           Width="220"
                                                           Foreground="#1e1e1e">
                                                    <Run Text="Логин должен быть:"/>
                                                    <LineBreak/>
                                                    <Run Text="• от 3 до 32 символов"/>
                                                    <LineBreak/>
                                                    <Run Text="• начинаться с буквы"/>
                                                    <LineBreak/>
                                                    <Run Text="• содержать только буквы, цифры и символы: _ . -"/>
                                                    <LineBreak/>
                                                    <Run Text="• без подряд идущих спецсимволов (_ . -)"/>
                                                </TextBlock>
                                            </Border>
                                        </ControlTemplate>
                                    </ToolTip.Template>
                                </ToolTip>
                            </TextBox.ToolTip>
                        </TextBox>
                        <TextBlock Text="Логин"
                   Foreground="#555555"
                   Margin="24,0,24,15"
                                   FontWeight="Medium"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   x:Name="RegisterUsernamePlaceholder"/>
                    </Grid>

                    <Grid>
                        <TextBox x:Name="RegisterEmailTextBox"
                                Style="{StaticResource RoundedTextBox}"
                                TextChanged="TextBox_TextChanged">
                            <TextBox.ToolTip>
                                <ToolTip Placement="Right" HorizontalOffset="10">
                                    <ToolTip.Template>
                                        <ControlTemplate TargetType="ToolTip">
                                            <Border Background="#f9f9f9"
                                                    BorderBrush="#3F64A9"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10">
                                                <TextBlock TextWrapping="Wrap" Width="220"
                                                           Foreground="#1e1e1e"
                                                           Text="Email должен соответсвовать формату email@example.com"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToolTip.Template>
                                </ToolTip>
                            </TextBox.ToolTip>
                        </TextBox>
                        <TextBlock Text="E-mail"
                                  Foreground="#555555"
                                  Margin="24,0,24,15"
                                  FontWeight="Medium"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  x:Name="RegisterEmailPlaceholder"/>
                    </Grid>

                    <Grid>
                        <TextBox x:Name="RegisterPasswordBox"
                                 Style="{StaticResource RoundedTextBox}"
                                 TextChanged="PasswordBox_TextChanged"
                                 LostFocus="PasswordBox_LostFocus"
                                 Loaded="PasswordBox_Loaded"
                                 DataObject.Pasting="PasswordBox_Pasting">
                            <TextBox.ToolTip>
                                <ToolTip Placement="Right" HorizontalOffset="10">
                                    <ToolTip.Template>
                                        <ControlTemplate TargetType="ToolTip">
                                            <Border Background="#f9f9f9"
                                                    BorderBrush="#3F64A9"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="10">
                                                <TextBlock TextWrapping="Wrap" Width="220"
                                                           Foreground="#1e1e1e"
                                                           Text="Пароль может содержать любые символы, но не должен быть больше 32 символов и состоять только из 1 пробела"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToolTip.Template>
                                </ToolTip>
                            </TextBox.ToolTip>
                        </TextBox>

                        <!-- Placeholder -->
                        <TextBlock Text="Пароль"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="24,0,50,15"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   x:Name="RegisterPasswordPlaceholder"/>

                        <!-- Глазик -->
                        <Button x:Name="RegisterShowPasswordButton"
                                Width="30" Height="30"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Margin="25,0,10,15"
                                Cursor="Hand"
                                PreviewMouseLeftButtonDown="ShowPasswordButton_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ShowPasswordButton_PreviewMouseLeftButtonUp">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="👁" FontSize="14"/>
                        </Button>
                    </Grid>

                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="RegisterButton" Width="120" Height="38"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                                Grid.Column="0"
                            Margin="0,10,0,0"
                        Background="#3F64A9"
                            Click="ButtonLogin_Click"
                        BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20">
                                        <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Войти"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Изменение цвета при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#5F84C9"/>
                                            <!-- более тёмный -->
                                        </Trigger>
                                        <!-- нажатие -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#7FA4E9"/>
                                            <!-- ещё темнее -->
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BackButton" Width="120" Height="38"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                                Grid.Column="2"
                            Margin="0,10,0,0"
                        Background="#E0E0E0"
                            Click="ButtonBack_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="20">
                                        <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Назад"
                                           FontWeight="SemiBold"
                                           Foreground="#1e1e1e"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Изменение цвета при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#C0C0C0"/>
                                            <!-- более тёмный -->
                                        </Trigger>
                                        <!-- нажатие -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#a0a0a0"/>
                                            <!-- ещё темнее -->
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                </StackPanel>

                <!-- ПРОФИЛЬ ПОЛЬЗОВАТЕЛЯ -->
                <StackPanel x:Name="UserPanel"
                    Margin="30, 20"
                            Visibility="Collapsed"
                    VerticalAlignment="Top" Cursor="">

                    <!-- Заголовок -->
                    <TextBlock x:Name="UsernameProfileText"
                               Text="Username"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <!-- E-mail -->
                    <TextBlock x:Name="EmailProfileText"
                               Text="email@example.com"
                   Foreground="#9b9b9b"
                               FontSize="13"
                   Margin="0,0,0,30"/>


                    <!-- Статистика (карточки) -->
                    <TextBlock Text="Статистика"
                   Foreground="#E0E0E0"
                   FontSize="18"
                   FontWeight="Medium"
                   Margin="10,0,0,10"/>

                    <UniformGrid Columns="2" Margin="0,0,0,18" Height="263">

                        <Grid Margin="0,0,8,8">

                            <!-- Карточка -->
                            <Border CornerRadius="15"
                                    Padding="16,25,16,13"
                                    BorderBrush="#3F64A9"
                                    BorderThickness="0,0,2,2">

                                <!-- Градиент -->
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                                        <GradientStop Color="#1F1F1F" Offset="0"/>
                                        <GradientStop Color="#2A2A2A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>

                                <!-- Контент -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Верх: иконка + число -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎹"
                                                   FontSize="24"
                                                   Foreground="#E0E0E0"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock x:Name="TracksCountText"
                                                   Text="24"
                                                   Foreground="#E0E0E0"
                                                   FontSize="24"
                                                   FontWeight="Bold"/>
                                    </StackPanel>

                                    <!-- Низ: описание -->
                                    <TextBlock Grid.Row="1"
                                               Text="Сыграно композиций"
                                               Foreground="#9B9B9B"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Margin="8,0,0,8">

                            <!-- Карточка -->
                            <Border CornerRadius="15"
                                    Padding="16,25,16,13"
                                    BorderBrush="#3F64A9"
                                    BorderThickness="0,0,2,2">

                                <!-- Градиент -->
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                                        <GradientStop Color="#1F1F1F" Offset="0"/>
                                        <GradientStop Color="#2A2A2A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>

                                <!-- Контент -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Верх: иконка + число -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="❤"
                                                   FontSize="24"
                                                   Foreground="#E0E0E0"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock x:Name="FavouritesCountText"
                                                   Text="0"
                                                   Foreground="#E0E0E0"
                                                   FontSize="24"
                                                   FontWeight="Bold"/>
                                    </StackPanel>

                                    <!-- Низ: описание -->
                                    <TextBlock Grid.Row="1"
                                               Text="В избранном"
                                               Foreground="#9B9B9B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Bottom"
                                               FontSize="13"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Margin="0,8,8,0">

                            <!-- Карточка -->
                            <Border CornerRadius="15"
                                    Padding="16,25,16,13"
                                    BorderBrush="#3F64A9"
                                    BorderThickness="0,0,2,2">

                                <!-- Градиент -->
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                                        <GradientStop Color="#1F1F1F" Offset="0"/>
                                        <GradientStop Color="#2A2A2A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>

                                <!-- Контент -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Верх: иконка + число -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✨"
                                                   FontSize="24"
                                                   Foreground="#E0E0E0"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock x:Name="StarsCountText"
                                                   Text="9"
                                                   Foreground="#E0E0E0"
                                                   FontSize="24"
                                                   FontWeight="Bold"/>
                                    </StackPanel>

                                    <!-- Низ: описание -->
                                    <TextBlock Grid.Row="1"
                                               Text="Получено звёзд"
                                               Foreground="#9B9B9B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Bottom"
                                               FontSize="13"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Margin="8,8,0,0">

                            <!-- Карточка -->
                            <Border CornerRadius="15"
                                    Padding="16,25,16,13"
                                    BorderBrush="#3F64A9"
                                    BorderThickness="0,0,2,2">

                                <!-- Градиент -->
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                                        <GradientStop Color="#1F1F1F" Offset="0"/>
                                        <GradientStop Color="#2A2A2A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>

                                <!-- Контент -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Верх: иконка + число -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔥"
                                                   FontSize="24"
                                                   Foreground="#E0E0E0"
                                                   Margin="0,0,1.5,0"/>
                                        <TextBlock x:Name="StreakText"
                                                   Text="5 дн."
                                                   Foreground="#E0E0E0"
                                                   FontSize="24"
                                                   FontWeight="Bold"/>
                                    </StackPanel>

                                    <!-- Низ: описание -->
                                    <TextBlock Grid.Row="1"
                                               Text="Стрик"
                                               Foreground="#9B9B9B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Bottom"
                                               FontSize="13"/>
                                </Grid>
                            </Border>
                        </Grid>

                    </UniformGrid>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <Button x:Name="EditUserButton"
                                Height="38"
                                Width="190"
                                HorizontalAlignment="Center"
                                Cursor="Hand"
                                Click="EditUser_Click"
                                Grid.Column="0"
                                Margin="0,0,5,0"
                                Background="#3F64A9"
                                BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="20">
                                        <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Редактировать профиль"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Изменение цвета при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#5F84C9"/>
                                            <!-- более тёмный -->
                                        </Trigger>
                                        <!-- нажатие -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#7FA4E9"/>
                                            <!-- ещё темнее -->
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="LogoutButton"
                                Height="38"
                                Width="90"
                            HorizontalAlignment="Center"
                            Cursor="Hand"
                                Margin="5,0,0,0"
                            Grid.Column="2"
                            Background="#E0E0E0"
                            Click="ButtonLogout_Click"
                            BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="20">
                                        <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Выйти"
                                           FontWeight="SemiBold"
                                           Foreground="#1e1e1e"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Изменение цвета при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#C0C0C0"/>
                                            <!-- более тёмный -->
                                        </Trigger>
                                        <!-- нажатие -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#a0a0a0"/>
                                            <!-- ещё темнее -->
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                </StackPanel>

                <!-- РЕДАКТИРОВАНИЕ ПРОФИЛЯ -->
                <StackPanel x:Name="UserEditPanel"
                            Margin="30, 20"
                            Visibility="Collapsed"
                            VerticalAlignment="Top" Cursor="">
                    <DockPanel Margin="0,0,0,30">

                        <!-- Заголовок -->
                        <TextBlock Text="Редактирование"
               Foreground="White"
               FontSize="22"
               FontWeight="Bold"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
                                   DockPanel.Dock="Left"/>

                        <!-- Крестик -->
                        <Button Width="22" Height="22"
                            Style="{StaticResource IconButtonStyle}"
                            Click="BackToProfile_Click"
                                DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <Image Source="/Images/cross.png"/>
                        </Button>

                    </DockPanel>

                    <!-- ОСНОВНАЯ ИНФОРМАЦИЯ -->
                    <TextBlock Text="Основная информация"
               Foreground="#6A9FFF"
               FontSize="16"
               FontWeight="SemiBold"
               Margin="15,0,0,10"/>

                    <StackPanel HorizontalAlignment="Stretch">
                        <!-- Username -->
                        <Grid>
                            <TextBox x:Name="EditUsernameBox"
                                 Style="{StaticResource TransparentTextBox}"
                                 TextChanged="TextBox_TextChanged">
                                <TextBox.ToolTip>
                                    <ToolTip Placement="Right" HorizontalOffset="10">
                                        <ToolTip.Template>
                                            <ControlTemplate TargetType="ToolTip">
                                                <Border Background="#f9f9f9"
                                                        BorderBrush="#3F64A9"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Width="220"
                                                               Foreground="#1e1e1e">
                                                        <Run Text="Логин должен быть:"/>
                                                        <LineBreak/>
                                                        <Run Text="• от 3 до 32 символов"/>
                                                        <LineBreak/>
                                                        <Run Text="• начинаться с буквы"/>
                                                        <LineBreak/>
                                                        <Run Text="• содержать только буквы, цифры и символы: _ . -"/>
                                                        <LineBreak/>
                                                        <Run Text="• без подряд идущих спецсимволов (_ . -)"/>
                                                    </TextBlock>
                                                </Border>
                                            </ControlTemplate>
                                        </ToolTip.Template>
                                    </ToolTip>
                                </TextBox.ToolTip>
                            </TextBox>
                            <TextBlock Text="Логин"
                                   Foreground="#888888"
                                   Margin="24,0,24,15"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   x:Name="EditUsernamePlaceholder"/>
                        </Grid>

                        <!-- Email -->
                        <Grid>
                            <TextBox x:Name="EditEmailBox"
                Style="{StaticResource TransparentTextBox}"
                TextChanged="TextBox_TextChanged">
                                <TextBox.ToolTip>
                                    <ToolTip Placement="Right" HorizontalOffset="10">
                                        <ToolTip.Template>
                                            <ControlTemplate TargetType="ToolTip">
                                                <Border Background="#f9f9f9"
                                                        BorderBrush="#3F64A9"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <TextBlock TextWrapping="Wrap"
                                                               Width="220"
                                                               Foreground="#1e1e1e"
                                                               Text="Email должен соответсвовать формату email@example.com"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToolTip.Template>
                                    </ToolTip>
                                </TextBox.ToolTip>
                            </TextBox>
                            <TextBlock Text="E-mail"
                                           Foreground="#555555"
                                           Margin="24,0,24,15"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           x:Name="EditEmailPlaceholder" Cursor=""/>

                        </Grid>

                        <!-- Кнопки -->
                        <Button x:Name="SaveProfileButton"
                                        Height="38"
                                        Width="160"
                                        HorizontalAlignment="Right"
                                        Cursor="Hand"
                                        Grid.Column="0"
                                        Click="SaveProfile_Click"
                                        Margin="0,0,5,0"
                                        Background="#3F64A9"
                                        BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="20">
                                        <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="Сохранить изменения"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Изменение цвета при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#5F84C9"/>
                                            <!-- более тёмный -->
                                        </Trigger>
                                        <!-- нажатие -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#7FA4E9"/>
                                            <!-- ещё темнее -->
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <Separator Margin="-30,20" Background="#111"/>

                    <!-- БЕЗОПАСНОСТЬ -->
                    <TextBlock Text="Безопасность"
               Foreground="#6A9FFF"
               FontSize="16"
               FontWeight="SemiBold"
               Margin="15,0,0,10"/>

                    <!-- ПАНЕЛЬ ПАРОЛЯ -->
                    <StackPanel HorizontalAlignment="Stretch">

                        <Grid>
                            <TextBox x:Name="CurrentPasswordBox"
                                         Style="{StaticResource TransparentTextBox}"
                                         TextChanged="PasswordBox_TextChanged"
                                         LostFocus="PasswordBox_LostFocus"
                                         Loaded="PasswordBox_Loaded"
                                         DataObject.Pasting="PasswordBox_Pasting"/>

                            <!-- Placeholder -->
                            <TextBlock Text="Текущий пароль"
                                           Foreground="#555555"
                                           FontWeight="Medium"
                                           Margin="24,0,50,15"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           x:Name="EditCurrentPasswordPlaceholder"/>

                            <!-- Глазик -->
                            <Button x:Name="EditCurrentShowPasswordButton"
                                        Width="30" Height="30"
                                        HorizontalAlignment="Right"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="25,0,10,15"
                                        Cursor="Hand"
                                        PreviewMouseLeftButtonDown="ShowPasswordButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ShowPasswordButton_PreviewMouseLeftButtonUp">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="👁" FontSize="14" Foreground="#e0e0e0"/>
                            </Button>
                        </Grid>

                        <Grid>
                            <TextBox x:Name="NewPasswordBox"
                                         Style="{StaticResource TransparentTextBox}"
                                         TextChanged="PasswordBox_TextChanged"
                                         LostFocus="PasswordBox_LostFocus"
                                         Loaded="PasswordBox_Loaded"
                                         DataObject.Pasting="PasswordBox_Pasting">
                                <TextBox.ToolTip>
                                    <ToolTip Placement="Right" HorizontalOffset="10">
                                        <ToolTip.Template>
                                            <ControlTemplate TargetType="ToolTip">
                                                <Border Background="#f9f9f9"
                                                        BorderBrush="#3F64A9"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <TextBlock TextWrapping="Wrap" Width="220"
                                                               Foreground="#1e1e1e"
                                                               Text="Пароль может содержать любые символы, но не должен быть больше 32 символов и состоять только из 1 пробела"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToolTip.Template>
                                    </ToolTip>
                                </TextBox.ToolTip>
                            </TextBox>

                            <!-- Placeholder -->
                            <TextBlock Text="Новый пароль"
                                           Foreground="#555555"
                                           FontWeight="Medium"
                                           Margin="24,0,50,15"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           x:Name="EditNewPasswordPlaceholder"/>

                            <!-- Глазик -->
                            <Button x:Name="EditNewShowPasswordButton"
                                        Width="30" Height="30"
                                        HorizontalAlignment="Right"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="25,0,10,15"
                                        Cursor="Hand"
                                        PreviewMouseLeftButtonDown="ShowPasswordButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ShowPasswordButton_PreviewMouseLeftButtonUp">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="👁" FontSize="14" Foreground="#e0e0e0"/>
                            </Button>
                        </Grid>

                        <Grid>
                            <TextBox x:Name="RepeatPasswordBox"
                                         Style="{StaticResource TransparentTextBox}"
                                         TextChanged="PasswordBox_TextChanged"
                                         LostFocus="PasswordBox_LostFocus"
                                         Loaded="PasswordBox_Loaded"
                                         DataObject.Pasting="PasswordBox_Pasting"/>

                            <!-- Placeholder -->
                            <TextBlock Text="Подтверждение нового пароля"
                                           Foreground="#555555"
                                           FontWeight="Medium"
                                           Margin="24,0,50,15"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           x:Name="EditRepeatPasswordPlaceholder"/>

                            <!-- Глазик -->
                            <Button x:Name="EditRepeatCurrentShowPasswordButton"
                                        Width="30" Height="30"
                                        HorizontalAlignment="Right"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Margin="25,0,10,15"
                                        Cursor="Hand"
                                        PreviewMouseLeftButtonDown="ShowPasswordButton_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="ShowPasswordButton_PreviewMouseLeftButtonUp">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="OverridesDefaultStyle" Value="True"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="👁" FontSize="14" Foreground="#e0e0e0"/>
                            </Button>
                        </Grid>

                        <!-- СОХРАНИТЬ ПАРОЛЬ -->
                        <Button x:Name="SavePasswordButton"
                                    Height="38"
                                    Width="160"
                                    HorizontalAlignment="Right"
                                    Cursor="Hand"
                                    Grid.Column="0"
                                    Click="SavePassword_Click"
                                    Margin="0,0,5,0"
                                    Background="#3F64A9"
                                    BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="20">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="Сохранить пароль"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Изменение цвета при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#5F84C9"/>
                                            <!-- более тёмный -->
                                        </Trigger>
                                        <!-- нажатие -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#7FA4E9"/>
                                            <!-- ещё темнее -->
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                </StackPanel>

            </Grid>
        </Grid>

        <!-- КНОПКА ВЫХОД -->
        <Button Grid.Row="1"
            Width="32" Height="32" Margin="20"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="ButtonExit_Click"
            Style="{StaticResource IconButtonStyle}">
            <!--<Image Source="/Images/exit.png"/>-->
            <svgc:SvgViewbox Source="/Images/exit.svg"/>
        </Button>


    </Grid>
</Window>