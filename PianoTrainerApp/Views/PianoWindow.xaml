<Window x:Class="PianoTrainerApp.Views.PianoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Планета Ре-минор" Height="650" Width="1050"
        MinHeight="650" MinWidth="1050"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- верхняя панель -->
            <RowDefinition Height="*"/>
            <!-- основной контент -->
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="0"
            Background="#111111"
            BorderBrush="#3F64A9"
            BorderThickness="0,0,0,3"
            Padding="40,0">

            <Grid Margin="0,0,0,-3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Центр: обратный отсчёт -->
                <TextBlock x:Name="CountdownText"
                       Text="3"
                       FontSize="40"
                       FontWeight="Bold"
                       Foreground="#e0e0e0"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Grid.ColumnSpan="3"/>

                <!-- Подсказка (скрытая) -->
                <TextBlock x:Name="HintText"
                       Text="Играй ноты на своем инструменте"
                       Foreground="#e0e0e0"
                       FontSize="13"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Grid.Column="2"/>

                <!-- Левая часть -->
                <StackPanel x:Name="ProgressPanel"
                        Grid.Column="0"
                            Visibility="Collapsed"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                    <!-- Прогресс -->
                    <Grid x:Name="ProgressSlider" Width="300" Height="10" Margin="0,0,10,0">
                        <!-- фон -->
                        <Border Background="#E0E0E0" CornerRadius="5"/>

                        <!-- заполнение -->
                        <Border x:Name="ProgressFill"
                            Background="#3F64A9"
                            CornerRadius="5"
                            Width="0"
                            HorizontalAlignment="Left"/>
                    </Grid>

                    <!-- Проценты -->
                    <TextBlock x:Name="ProgressText"
                           Text="0%"
                           Foreground="#e0e0e0"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Точность -->
                <StackPanel x:Name="AccuracyPanel"
                            Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            Margin="0 0 -19 0">
                    <TextBlock Text="Точность попаданий"
                               Foreground="#e0e0e0"
                               FontWeight="Regular"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Margin="0 0 10 0"/>
                    <TextBlock x:Name="AccuracyText"
                               Text="0%" Foreground="#4992FF"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               FontSize="24"
                               Margin="5,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Hidden"
                      x:Name="NotesScrollViewer">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <!-- зона падения нот -->
                    <RowDefinition Height="200"/>
                    <!-- клавиатура -->
                </Grid.RowDefinitions>

                <!-- Слой нот (они падают сверху) -->
                <Canvas x:Name="NotesCanvas"
                        Grid.Row="0"
                        VerticalAlignment="Stretch"/>

                <!-- Слой клавиш (пианино внизу) -->
                <Grid VerticalAlignment="Stretch"
                      Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding WhiteKeys}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="40" Height="200" BorderBrush="Black" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="White"/>
                                            <Style.Triggers>
                                                <!-- подсветка при нажатии -->
                                                <DataTrigger Binding="{Binding IsPressed}" Value="True">
                                                    <Setter Property="Background" Value="Orange"/>
                                                </DataTrigger>
                                                <!-- правильная нота -->
                                                <DataTrigger Binding="{Binding IsCorrectlyPlayed}" Value="True">
                                                    <Setter Property="Background" Value="LightGreen"/>
                                                </DataTrigger>
                                                <!-- неправильная нота -->
                                                <DataTrigger Binding="{Binding IsCorrectlyPlayed}" Value="False">
                                                    <Setter Property="Background" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Note}" VerticalAlignment="Bottom" HorizontalAlignment="Center" FontSize="10"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding BlackKeys}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="25" Height="120" BorderBrush="Black" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Black"/>
                                            <Style.Triggers>
                                                <!-- подсветка при нажатии -->
                                                <DataTrigger Binding="{Binding IsPressed}" Value="True">
                                                    <Setter Property="Background" Value="Orange"/>
                                                </DataTrigger>
                                                <!-- правильная нота -->
                                                <DataTrigger Binding="{Binding IsCorrectlyPlayed}" Value="True">
                                                    <Setter Property="Background" Value="LightGreen"/>
                                                </DataTrigger>
                                                <!-- неправильная нота -->
                                                <DataTrigger Binding="{Binding IsCorrectlyPlayed}" Value="False">
                                                    <Setter Property="Background" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding PositionX}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>
        <!--<TextBlock x:Name="CountdownText"
Text="3"
FontSize="46"
FontWeight="Bold"
Foreground="#e0e0e0"
            Margin="0,0,0,200"
Visibility="Collapsed"
HorizontalAlignment="Center"
VerticalAlignment="Center"
Grid.Row="1"/>-->
    </Grid>
</Window>
